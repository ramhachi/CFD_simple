FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 1.78;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1.78;
    }
    outlet
    {
        type            zeroGradient;
    }
    ground
    {
        type            omegaWallFunction;
        value           uniform 1.78;
    }
    topAndSides
    {
        type            symmetry;
    }
    ".*"
    {
        type            omegaWallFunction;
        value           uniform 1.78;
    }
}

